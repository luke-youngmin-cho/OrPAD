{
  "name": "formatpad",
  "version": "1.0.0-beta.2",
  "productName": "FormatPad",
  "description": "Fast multi-format viewer and editor — Markdown, JSON, YAML, CSV/TSV, TOML, XML, HTML, Mermaid, .env, plain text/log.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "node scripts/build-renderer.js",
    "build:web": "node scripts/build-web.js",
    "build:web:min": "node scripts/build-web.js --minify",
    "prestart": "npm run build:renderer",
    "dist": "npm run dist:win",
    "dist:win": "npm run build:renderer && electron-builder --win --publish=never",
    "dist:mac": "npm run build:renderer && electron-builder --mac --publish=never",
    "dist:all": "npm run build:renderer && electron-builder -mw --publish=never",
    "dist:portable": "npm run build:renderer && electron-builder --win portable --publish=never",
    "release:write-updater-key": "node scripts/write-updater-public-key.mjs",
    "release:manifest": "node scripts/create-release-manifest.mjs",
    "build:icons": "png2icons assets/icon.png assets/icon -icns -hm",
    "size": "node scripts/bundle-size.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:electron": "playwright test --project=electron",
    "test:web": "playwright test --project=web-chromium",
    "test:web:compat": "playwright test --project=web-chromium --project=web-firefox --project=web-webkit",
    "lh": "npx --yes lighthouse http://localhost:4173 --preset=pwa --chrome-flags='--headless=new' --quiet --output=html --output-path=./lighthouse-report.html"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "playwright": "1.59.1",
    "png2icons": "^2.0.1",
    "workbox-cli": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language-data": "^6.5.2",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@sentry/browser": "^10.50.0",
    "@sentry/electron": "^7.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^6.14.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.0",
    "ini": "^6.0.0",
    "isomorphic-git": "^1.37.5",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "jsonrepair": "^3.14.0",
    "katex": "^0.16.45",
    "lz-string": "^1.5.0",
    "marked": "^15.0.0",
    "marked-gfm-heading-id": "^4.1.0",
    "marked-highlight": "^2.2.0",
    "mermaid": "^11.14.0",
    "papaparse": "^5.5.3",
    "plausible-tracker": "^0.3.9",
    "smol-toml": "^1.6.1",
    "svg-pan-zoom": "^3.6.2",
    "turndown": "^7.2.4",
    "v8-compile-cache": "2.3.0"
  }
}

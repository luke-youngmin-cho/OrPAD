{
  "name": "formatpad",
  "version": "1.0.0-beta.1",
  "productName": "FormatPad",
  "description": "Fast multi-format viewer and editor — Markdown, JSON, YAML, CSV/TSV, TOML, XML, HTML, Mermaid, .env, plain text/log.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "node scripts/build-renderer.js",
    "build:web": "node scripts/build-web.js",
    "build:web:min": "node scripts/build-web.js --minify",
    "prestart": "npm run build:renderer",
    "dist": "npm run dist:win",
    "dist:win": "npm run build:renderer && electron-builder --win --publish=never",
    "dist:mac": "npm run build:renderer && electron-builder --mac --publish=never",
    "dist:all": "npm run build:renderer && electron-builder -mw --publish=never",
    "dist:portable": "npm run build:renderer && electron-builder --win portable --publish=never",
    "build:icons": "png2icons assets/icon.png assets/icon -icns -hm"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "png2icons": "^2.0.1"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language-data": "^6.5.2",
    "ajv": "^6.14.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.0",
    "ini": "^6.0.0",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "jsonrepair": "^3.14.0",
    "katex": "^0.16.45",
    "marked": "^15.0.0",
    "marked-gfm-heading-id": "^4.1.0",
    "marked-highlight": "^2.2.0",
    "mermaid": "^11.14.0",
    "papaparse": "^5.5.3",
    "smol-toml": "^1.6.1",
    "svg-pan-zoom": "^3.6.2",
    "tabulator-tables": "^6.4.0",
    "turndown": "^7.2.4"
  }
}
